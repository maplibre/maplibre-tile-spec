#!/usr/bin/env just --justfile

main_crate := "fast-mvt"
just := quote(just_executable())
root_justfile := "../../justfile"
root_dir := "../.."

# Show available commands
@_default:
    {{just}} --list

# Run the fast local CI set
ci: codegen-check fmt-check clippy test-feature-matrix bench-quick

# Format all code with rustfmt
fmt:
    {{just}} --justfile {{root_justfile}} --working-directory {{root_dir}} rust::fmt

# Check formatting without changing files
fmt-check:
    cargo fmt --all -- --check

# Compile all fast-mvt targets with all features
check:
    cargo check -p {{main_crate}} --all-targets --all-features

# Run clippy for all fast-mvt targets
clippy:
    cargo clippy -p {{main_crate}} --all-targets --all-features -- -D warnings

# Run the default test suite
test:
    cargo test -p {{main_crate}}

# Run tests with every supported feature combination
test-feature-matrix:
    {{just}} --justfile {{root_justfile}} --working-directory {{root_dir}} rust::test-fast-mvt

# Build documentation for fast-mvt
docs:
    cargo doc -p {{main_crate}} --all-features --no-deps

# Generate and open an HTML coverage report (requires cargo-llvm-cov)
coverage:
    cargo llvm-cov -p {{main_crate}} --all-features --open

# Generate LCOV coverage at ../target/llvm-cov/fast-mvt.lcov (requires cargo-llvm-cov)
coverage-lcov:
    mkdir -p ../target/llvm-cov
    cargo llvm-cov -p {{main_crate}} --all-features --lcov --output-path ../target/llvm-cov/fast-mvt.lcov

# Run full Criterion benchmarks
bench: bench-decode bench-encode

# Compile and smoke-test benchmarks quickly, suitable for CI
bench-quick: bench-decode-quick bench-encode-quick

# Compare decoding speed between fast-mvt and mvt-reader
bench-decode:
    cargo bench -p {{main_crate}} --bench decoder --features reader

# Compare encoding speed between fast-mvt and mvt
bench-encode:
    cargo bench -p {{main_crate}} --bench encoder --all-features

# Compile and smoke-test the decode benchmark quickly, suitable for CI
bench-decode-quick:
    cargo bench -p {{main_crate}} --bench decoder --features reader -- --test

# Compile and smoke-test the encode benchmark quickly, suitable for CI
bench-encode-quick:
    cargo bench -p {{main_crate}} --bench encoder --all-features -- --test

# Alias for benchmark targets comparing the supported MVT crates
bench-compare: bench

# Regenerate protobuf bindings and fail if checked-in output changes
codegen-check:
    {{just}} --justfile {{root_justfile}} --working-directory {{root_dir}} rust::codegen-check-fast-mvt

# Refresh generated protobuf bindings and formatting
autofix:
    {{just}} --justfile {{root_justfile}} --working-directory {{root_dir}} rust::autofix-fast-mvt

{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM"],
		"rootDir": "js",
		"outDir": "dist",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"strict": true,
		"skipLibCheck": true
	},
	"include": ["js/**/*"],
	"exclude": ["node_modules", "dist", "pkg", "**/*.spec.ts", "**/*.bench.ts"]
}

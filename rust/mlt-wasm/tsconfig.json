{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ES2020",
		"moduleResolution": "bundler",
		"lib": ["ES2020", "DOM"],
		"rootDir": "js",
		"outDir": "dist",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"strict": true,
		"skipLibCheck": true
	},
	"include": ["js/**/*"],
	"exclude": ["node_modules", "dist", "pkg"]
}
